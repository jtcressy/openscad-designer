{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "openscad-designer",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "minify": true,
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": "./dist/ui",
    "binding": "ASSETS",
    "run_worker_first": ["/mcp", "/health"]
  }
}
